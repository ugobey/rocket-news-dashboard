<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%-title%></title>

        <link id="bootstrapStylesheet" href="/css/bootstrap-5.3.3/bootstrap.min.css" rel="stylesheet" />
        <link href="/css/animate.min.css" rel="stylesheet" />
        <link href="/fonts/fontawesome-free-7.2.0/css/all.min.css" rel="stylesheet" />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />

        <link id="dashboardThemeStylesheet" href="/css/themes/graphite.css?<%=randomKey%>" rel="stylesheet" />

        <script src="/js/jquery-3.7.1.min.js"></script>
        <script src="/js/bootstrap-5.3.3/bootstrap.bundle.min.js"></script>

        <!-- Google Tag Manager -->
        <script>
            (function (w, d, s, l, i) {
                w[l] = w[l] || [];
                w[l].push({
                    'gtm.start': new Date().getTime(),
                    event: 'gtm.js'
                });
                var f = d.getElementsByTagName(s)[0],
                    j = d.createElement(s),
                    dl = l != 'dataLayer' ? '&l=' + l : '';
                j.async = true;
                j.src =
                    'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
                f.parentNode.insertBefore(j, f);
            })(window, document, 'script', 'dataLayer', 'GTM-5P7S7PRR');

        </script>
        <!-- End Google Tag Manager -->

        <script>
            // Maps API may call initMap before the body scripts run; bridge it safely.
            window.__googleMapsCallbackFired = false;
            window.__initMapImpl = null;
            window.initMap = function initMap () {
                window.__googleMapsCallbackFired = true;
                if (typeof window.__initMapImpl === 'function') {
                    window.__initMapImpl();
                }
            };

        </script>

        <script>
            // Load Google Maps with the persisted UI language before client code initializes the map.
            (function () {
                const mapsLang = localStorage.getItem("uiLanguage") === "he" ? "he" : "en";
                const s = document.createElement("script");
                s.src = "https://maps.googleapis.com/maps/api/js?callback=initMap&libraries=marker&language=" + mapsLang + "&key=<%=googleMapsApiKey%>&loading=async";
                s.async = true;
                document.head.appendChild(s);
            })();

        </script>

    </head>

    <body>
        <!-- Google Tag Manager (noscript) -->
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5P7S7PRR" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        <!-- End Google Tag Manager (noscript) -->

        <div class="container-fluid p-3 p-lg-4">
            <div class="row g-3">
                <!-- ==================== ALERTS ==================== -->
                <div id="homeFrontCommandAlertsTile" class="col-12 col-md-6 col-lg-2 col-xl-3">
                    <div id="pikudHeader" class="card table-card header-danger text-white mb-3">
                        <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#pikudBody" style="cursor: pointer">
                            <span><i class="fa-solid fa-bell me-2"></i><span data-i18n="alerts">Alerts</span></span>
                            <div class="d-flex align-items-center gap-2">
                                <span id="liveClock" class="live-clock">00:00:00</span>
                                <i class="fa-solid fa-chevron-down collapse-icon"></i>
                            </div>
                        </div>
                    </div>

                    <div id="pikudBody" class="collapse show">
                        <div class="card table-responsive tile" id="pikud_haoref_feed" style="overflow-y: auto;">
                            <table class=" table table-dark table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th width="10%" data-i18n="thTime">Time</th>
                                        <th width="5%" data-i18n="thType">Type</th>
                                        <th data-i18n="thLocation">Location</th>
                                        <th data-i18n="thZone">Zone</th>
                                    </tr>
                                </thead>
                                <tbody id="pikud_haoref_alerts" class="fw-medium"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ==================== ALERTS BY LOCATION + ZONE ==================== -->
                <div id="locationsZoneTile" class="col-12 col-md-6 col-lg-1 col-xl-2">
                    <!-- Locations -->
                    <div id="locationsHeader" class="card table-card header-danger text-white mb-3">
                        <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#locationsBody" style="cursor: pointer">
                            <span><i class="fa-solid fa-location-dot me-2"></i><span data-i18n="alertLocations">Alert Locations</span></span>
                            <i class="fa-solid fa-chevron-down collapse-icon"></i>
                        </div>
                    </div>
                    <div id="locationsBody" class="collapse show">
                        <div class="card table-responsive tile" id="locations_feed" style="max-height: 43vh; overflow-y: auto;">
                            <table class=" table table-dark table-sm mb-0">
                                <tbody id="alerted_locations_counter"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Zones -->
                    <div id="zonesHeader" class="card table-card header-danger text-white mt-3 mb-3">
                        <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#zonesBody" style="cursor: pointer">
                            <span><i class="fa-solid fa-map me-2"></i><span data-i18n="alertZones">Alert Zones</span></span>
                            <i class="fa-solid fa-chevron-down collapse-icon"></i>
                        </div>
                    </div>
                    <div id="zonesBody" class="collapse show">
                        <div class="card table-responsive tile" id="zones_feed" style="overflow-y: auto;">
                            <table class=" table table-dark table-sm mb-0">
                                <tbody id="alerted_zones_counter"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ==================== SUMMARY ==================== -->
                <div id="summaryLastAlertedTimesTile" class="col-12 col-md-6 col-lg-1 col-xl-2">
                    <!-- Alerts Summary -->
                    <div id="summaryHeader" class="card table-card header-primary text-white mb-3">
                        <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#summaryBody" style="cursor: pointer">
                            <span><i class="fa-solid fa-chart-pie me-2"></i><span data-i18n="alertsSummary">Alerts Summary</span></span>
                            <i class="fa-solid fa-chevron-down collapse-icon"></i>
                        </div>
                    </div>

                    <div id="summaryBody" class="collapse show">
                        <div class="card table-responsive tile">
                            <table class="table table-dark table-sm mb-0">
                                <tbody id="alerts_summary">
                                    <tr>
                                        <td><span data-i18n="totalAlerts">Total Alerts</span></td>
                                        <td class="text-end"><span id="totalAlertsCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <!-- Rare alert types stay hidden until at least one event of that type is recorded. -->
                                    <tr id="total_general_alerts_counter" style="display: none;">
                                        <td><span class="text-warning" data-i18n="totalGeneralAlerts">Total General Alerts</span></td>
                                        <td class="text-end"><span id="generalAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="total_earthquake_alerts_counter" style="display: none;">
                                        <td><span class="text-warning" data-i18n="totalEarthquakeAlerts">Total Earthquake Alerts</span></td>
                                        <td class="text-end"><span id="earthquakeAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="total_radiological_event_alerts_counter" style="display: none;">
                                        <td><span class="text-warning" data-i18n="totalRadiologicalAlerts">Total Radiological Event Alerts</span></td>
                                        <td class="text-end"><span id="radiologicalEventAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="total_tsunami_alerts_counter" style="display: none;">
                                        <td><span class="text-warning" data-i18n="totalTsunamiAlerts">Total Tsunami Alerts</span></td>
                                        <td class="text-end"><span id="tsunamiAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="total_hazardous_materials_alerts_counter" style="display: none;">
                                        <td><span class="text-warning" data-i18n="totalHazardousMaterialsAlerts">Total Hazardous Materials Alerts</span></td>
                                        <td class="text-end"><span id="hazardousMaterialsAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="total_terrorist_infiltration_alerts_counter" style="display: none;">
                                        <td><span class="text-warning" data-i18n="totalTerroristInfiltrationAlerts">Total Terrorist Infiltration Alerts</span></td>
                                        <td class="text-end"><span id="terroristInfiltrationAlertCounter" class="stat-number">0</span></td>
                                    </tr>



                                    <tr>
                                        <td><span data-i18n="totalDroneAlerts">Total Drone Alerts</span></td>
                                        <td class="text-end"><span id="droneAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr>
                                        <td><span data-i18n="totalRocketAlerts">Total Rocket Alerts</span></td>
                                        <td class="text-end"><span id="rocketAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr>
                                        <td><span data-i18n="droneShare">Drone Share</span></td>
                                        <td class="text-end"><span id="droneShareCounter" class="stat-number">0%</span></td>
                                    </tr>
                                    <tr>
                                        <td><span data-i18n="rocketShare">Rocket Share</span></td>
                                        <td class="text-end"><span id="rocketShareCounter" class="stat-number">0%</span></td>
                                    </tr>
                                    <tr>
                                        <td><span data-i18n="totalLocations">Total Locations</span></td>
                                        <td class="text-end"><span id="totalLocationsCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr>
                                        <td><span data-i18n="totalZones">Total Zones</span></td>
                                        <td class="text-end"><span id="totalZonesCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr>
                                        <td><span data-i18n="totalEarlyWarningsAll">Total Early Warnings (All)</span></td>
                                        <td class="text-end"><span id="totalEarlyWarningsAllCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="total_early_warnings_specific_counter" style="display: none">
                                        <td><span data-i18n="totalEarlyWarningsSpecific">Total Early Warnings (Specific)</span></td>
                                        <td class="text-end"><span id="totalEarlyWarningsSpecificCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="unmatched_cities_counter" style="display: none">
                                        <td><span data-i18n="totalUnmatchedCities">Total Unmatched Cities</span></td>
                                        <td class="text-end"><span id="totalUnmatchedCitiesCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="unmatched_cities" style="display: none">
                                        <td><span data-i18n="openUnmatchedCities">Open Unmatched Cities</span></td>
                                        <td class="text-end">
                                            <i id="show_unmatched_cities" class="fa-solid fa-arrow-up-right-from-square fa-xl icon-btn text-warning" style="cursor: pointer" title="Show Unmatched Cities"></i>
                                        </td>
                                    </tr>
                                    <tr id="error_counter" style="display: none">
                                        <td><span data-i18n="totalErrors">Total Errors</span></td>
                                        <td class="text-end"><span id="pikud_haoref_error_counter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="error_message" style="display: none">
                                        <td><span data-i18n="openErrorMessages">Open Error Messages</span></td>
                                        <td class="text-end">
                                            <i id="show_error_messages" class="fa-solid fa-arrow-up-right-from-square fa-xl text-warning" style="cursor: pointer" title="Show Error Messages"></i>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span data-i18n="soundAlerts">Sound Alerts</span></td>
                                        <td class="text-end">
                                            <i id="sound_alerts_icon" class="fa-solid fa-bell fa-xl" style="cursor: pointer"></i>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span data-i18n="fullscreen">Fullscreen</span></td>
                                        <td class="text-end">
                                            <i id="fullscreen_icon" class="fa-solid fa-expand fa-xl text-light" title="Enter Fullscreen"></i>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span data-i18n="settingsLabel">Settings</span></td>
                                        <td class="text-end">
                                            <i id="open_settings_icon" class="fa-solid fa-gear fa-xl text-light" title="Open Settings"></i>
                                        </td>
                                    </tr>
                                    <tr id="clear_pikud_history_row" style="display: none;">
                                        <td><span data-i18n="clearAlertHistory">Clear Alert History</span></td>
                                        <td class="text-end">
                                            <i id="clear_pikud_history_icon" class="fa-solid fa-trash-can fa-xl text-light"></i>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span data-i18n="testMode">Test Mode</span></td>
                                        <td class="text-end">
                                            <i id="test_mode_icon" class="fa-solid fa-play fa-xl text-light" title="Turn ON Test Mode"></i>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span data-i18n="appVersion">App Version</span></td>
                                        <td class="text-end"><span id="appVersion" class="stat-number"><%= appVersion %></span></td>
                                    </tr>
                                    <tr id="update_app_version" style="display: none">
                                        <td><span data-i18n="appUpdateAvailable">App Update Available</span></td>
                                        <td class="text-end">
                                            <i id="update_app_version_icon" class="fa-solid fa-arrows-rotate fa-xl text-warning" title="Reload with new version"></i>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>


                    <!-- Last Alerted Times -->
                    <div id="lastAlertedTimesHeader" class="card table-card header-danger text-white mt-3 mb-3">
                        <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#lastAlertedTimesBody" style="cursor: pointer">
                            <span><i class="fa-solid fa-clock me-2"></i><span data-i18n="lastAlertedTimes">Last Alerted Times</span></span>
                            <i class="fa-solid fa-chevron-down collapse-icon"></i>
                        </div>
                    </div>

                    <div id="lastAlertedTimesBody" class="collapse show">
                        <div class="card table-responsive tile" id="last_alerted_times_feed" style="overflow-y: auto;">
                            <table class=" table table-dark table-sm mb-0">
                                <tbody id="last_alerted_times">

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ==================== NEWS + MAP ==================== -->
                <div id="newsMapTile" class="col-12 col-md-12 col-lg-4 col-xl-5">
                    <!-- News -->
                    <div id="newsHeader" class="card table-card header-dark text-white mb-3">
                        <div class="card-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#newsBody" style="cursor: pointer">
                            <span class="section-header"><i class="fa-solid fa-newspaper me-2"></i><span data-i18n="newsUpdates">News Updates</span></span>
                            <div class="d-flex align-items-center gap-2">
                                <select id="rssFeedSelector" class="form-select form-select-sm bg-dark text-white border-0" style="display: none"></select>
                                <i class="fa-solid fa-chevron-down collapse-icon"></i>
                            </div>
                        </div>
                    </div>

                    <div id="newsBody" class="collapse show">
                        <div class="card table-responsive tile" id="rss_feed" style="max-height: 25vh; overflow-y: auto;">
                            <table class="table table-dark table-sm mb-0">
                                <tbody id="rss_alerts"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Map -->
                    <div id="mapHeader" class="card table-card header-danger text-white mt-3 mb-3">
                        <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#mapBody" style="cursor: pointer">
                            <span><i class="fa-solid fa-map-location-dot me-2"></i><span data-i18n="mapAlerts">Map Alerts</span></span>
                            <i class="fa-solid fa-chevron-down collapse-icon"></i>
                        </div>
                    </div>

                    <div id="mapBody" class="collapse show">
                        <div class="card table-responsive tile overflow-hidden" style="border-radius: 16px">
                            <div id="map"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal overlays for early warnings, diagnostics, and user settings. -->

        <!-- Early Warning Modal - Enter -->
        <div class="modal fade" id="earlyWarningModalEnter" tabindex="-1" aria-labelledby="earlyWarningModalEnterLabel">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content glass-modal bg-danger text-white border-0">
                    <!-- Header -->
                    <div class="modal-header border-0 px-4 pt-4 pb-3">
                        <h4 class="modal-title fw-semibold text-white" id="earlyWarningModalEnterLabel"><i class="fa-solid fa-circle-exclamation me-3 text-white"></i><span data-i18n="earlyWarningTitle">Early Missile Warning Alert</span></h4>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body px-4 py-1">
                        <div class="glass-inner p-4 rounded-4">

                            <span class="text-white-50 small mb-3"><span data-i18n="alertedAt">Alerted at</span> <strong id="earlyWarningOpenedAt"></strong></span>
                            &nbsp;&middot;&nbsp;
                            <span class="text-white-50 small mb-3"><span data-i18n="timeBeforeSirens">Estimated time before missile sirens:</span> <strong id="earlyWarningCountdown"></strong></span>
                            <br /><br />
                            <span data-i18n="earlyWarningAutoClose">This message will disappear automatically when the threat is no longer active.</span>
                            <br /><br />
                            <b data-i18n="affectedLocations">The following locations are affected:</b>
                            <br />

                            <div id="earlyWarningLocations" style="width: 100%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        </div>

        <!-- Early Warning Modal - Exit -->
        <div class="modal fade" id="earlyWarningModalExit" tabindex="-1" aria-labelledby="earlyWarningModalExitLabel">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content glass-modal bg-success text-white border-0">
                    <!-- Header -->
                    <div class="modal-header border-0 px-4 pt-4 pb-3">
                        <h4 class="modal-title fw-semibold text-white" id="earlyWarningModalExitLabel"><i class="fa-solid fa-circle-check me-3 text-white"></i><span data-i18n="safeToExitTitle">Safe To Exit Bomb Shelter</span></h4>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body px-4 py-1">
                        <div class="glass-inner p-4 rounded-4">
                            <span data-i18n="safeToExitBody">You can now exit the bomb shelter.</span>
                            <br /><br />
                            <span data-i18n="autoCloseAfter10s">This message will disappear automatically after 10 seconds.</span>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer border-0 px-4 pb-4">
                        <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal" data-i18n="close">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Error Messages Modal -->
        <div class="modal fade" id="errorMessagesModal" tabindex="-1" aria-labelledby="errorMessagesModalLabel">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content glass-modal bg-dark text-white border-0">
                    <!-- Header -->
                    <div class="modal-header border-0 px-4 pt-4 pb-3">
                        <h4 class="modal-title fw-semibold text-white" id="errorMessagesModalLabel"><i class="fa-solid fa-circle-exclamation me-3"></i><span data-i18n="errorMessagesTitle">Error Messages</span></h4>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body px-4 py-1">
                        <div class="glass-inner p-4 rounded-4">
                            <span data-i18n="errorMessagesDesc">Unique error messages received from the Pikud HaOref service.</span>
                            <br /><br />
                            <ul id="pikud_haoref_error_messages" style="width: 100%"></ul>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer border-0 px-4 pb-4">
                        <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal" data-i18n="close">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Unmatched Cities Modal -->
        <div class="modal fade" id="unmatchedCitiesModal" tabindex="-1" aria-labelledby="unmatchedCitiesModalLabel">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content glass-modal bg-dark text-white border-0">
                    <!-- Header -->
                    <div class="modal-header border-0 px-4 pt-4 pb-3">
                        <h4 class="modal-title fw-semibold text-white" id="unmatchedCitiesModalLabel"><i class="fa-solid fa-circle-exclamation me-3 text-white"></i><span data-i18n="unmatchedCitiesTitle">Unmatched Cities</span></h4>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body px-4 py-1">
                        <div class="glass-inner p-4 rounded-4">
                            <span data-i18n="unmatchedCitiesDesc">These are the unmatched cities received from the Pikud HaOref service.</span>
                            <br />
                            <br />
                            <ul id="unmatched_cities_messages" style="width: 100%"></ul>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer border-0 px-4 pb-4">
                        <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal" data-i18n="close">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Settings Modal -->
        <div class="modal fade" id="settingsModal" tabindex="-1" aria-labelledby="settingsModalLabel">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content glass-modal bg-dark">
                    <!-- Header -->
                    <div class="modal-header border-0 px-4 pt-4 pb-3">
                        <h4 class="modal-title fw-semibold text-white" id="settingsModalLabel"><i class="fa-solid fa-sliders me-3 text-primary"></i><span data-i18n="settingsModalTitle">Settings</span></h4>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body px-4 py-1">
                        <div class="glass-inner p-4 rounded-4">
                            <table class="table table-dark table-borderless mb-0">
                                <tr>
                                    <td width="45%" class="align-middle">
                                        <span class="text-white fw-medium" data-i18n="cityEarlyWarning">City (Early Warning)</span>
                                    </td>
                                    <td>
                                        <input class="form-control" type="text" id="citySearch" autocomplete="off" placeholder="Type city name..." data-i18n-placeholder="typeCityName" />

                                        <ul id="city_suggestions" class="list-group position-absolute w-100 mt-2 shadow-lg rounded-3 overflow-hidden" style="display: none; max-height: 320px; overflow-y: auto; z-index: 1060"></ul>
                                    </td>
                                    <td width="20%" class="text-end align-middle">
                                        <button class="btn btn-primary px-4 py-2 fw-semibold" id="saveCityButton"><i class="fa-solid fa-floppy-disk me-2"></i><span data-i18n="save">Save</span></button>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="pt-3">
                                        <hr class="text-white" />
                                    </td>
                                </tr>
                                <!-- Dashboard behavior preferences persisted in localStorage. -->
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium" data-i18n="pikudAutoScroll">Pikud HaOref Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_pikud_scroll" />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium" data-i18n="zonesAutoScroll">Zones Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_zones_scroll" />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium" data-i18n="locationsAutoScroll">Locations Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_locations_scroll" />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium" data-i18n="lastAlertedTimesAutoScroll">Last Alerted Times Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_last_alerted_times_scroll" />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium" data-i18n="rssAutoScroll">RSS Feed Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_rss_scroll" />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium" data-i18n="earlyWarningAutoScroll">Early Warning Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_early_warning_scroll" checked />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium" data-i18n="allowMapAutoMax">Allow Map Auto-Maximization</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_allow_map_auto_maximization" checked />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium" data-i18n="persistHistorySetting">Persist Alert History</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_persist_history" checked />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium" data-i18n="testModeType">Test Mode Type</span>
                                    </td>
                                    <td colspan="2">
                                        <select class="form-select" id="test_mode_type">
                                            <option value="alertByCity" data-i18n="testModeOptionAlertByCity">Alert by City</option>
                                            <option value="alertByRegion" data-i18n="testModeOptionAlertByRegion">Alert by Region</option>
                                            <option value="earlyWarning" data-i18n="testModeOptionEarlyWarning">Early Warning</option>
                                            <option value="nonMissileUAV" data-i18n="testModeOptionOtherAlertsOnly">Other Alerts Only</option>
                                        </select>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium" data-i18n="dashboardStyle">Dashboard Style</span>
                                    </td>
                                    <td colspan="2">
                                        <select class="form-select" id="css_style_theme">
                                            <option value="apex_terminal">Apex Terminal</option>
                                            <option value="command_center">Command Center</option>
                                            <option value="graphite">Graphite Pro (Default)</option>
                                            <option value="graphite_small">Graphite Pro (Small)</option>
                                            <option value="market_terminal">Market Terminal</option>
                                            <option value="stripe_edition">Stripe Edition</option>
                                        </select>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium" data-i18n="language">Language</span>
                                    </td>
                                    <td colspan="2">
                                        <select class="form-select" id="ui_language">
                                            <option value="en">English</option>
                                            <option value="he">&#x202B;עברית</option>
                                        </select>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer border-0 px-4 pb-4">
                        <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal" data-i18n="close">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            // Inject server-rendered configuration once so the static client bundle can stay framework-agnostic.
            window.__appConfig = {
                appVersion: "<%= appVersion %>",
                randomKey:  "<%= randomKey %>",
                cities:     <%- cities %>,
                rssFeeds:   <%- rssFeeds %>
            };
        </script>
        <script src="/js/main.js"></script>
    </body>

</html>
