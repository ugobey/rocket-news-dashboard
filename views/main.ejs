            // ==================== APP VERSION CHECK ====================
            // Calls the version_check service which runs `npm outdated` server-side
            // and compares the local package version against the latest on the registry.
            // If a newer version exists, the upgrade icon is revealed in the Summary table.
            async function checkAppVersion () {
                try {
                    const versionCheck = await ajaxHandler("version_check");

                    if (versionCheck && versionCheck.updateAvailable) {
                        const latestVersion = versionCheck.latestVersion; // Available for display if needed

                        $("#update_app_version").show(); // Reveal the upgrade-available row
                    } else {
