<!DOCTYPE html>
<html lang="en">

    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%-title%></title>

        <link href="/css/bootstrap-5.3.3/bootstrap.min.css" rel="stylesheet" />
        <link href="/css/animate.min.css" rel="stylesheet" />
        <link href="/fonts/fontawesome-free-7.2.0/css/all.min.css" rel="stylesheet" />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />

        <link id="dashboardThemeStylesheet" href="/css/themes/default.css" rel="stylesheet" />

        <script src="/js/jquery-3.7.1.min.js"></script>
        <script src="/js/bootstrap-5.3.3/bootstrap.bundle.min.js"></script>
        <script src="/js/moment-2.30.1.min.js"></script>

        <script src="https://maps.googleapis.com/maps/api/js?callback=initMap&libraries=marker&key=<%=googleMapsApiKey%>&loading=async" async></script>

    </head>

    <body>
        <div class="container-fluid p-3 p-lg-4">
            <div class="row g-3">
                <!-- ==================== HOME FRONT COMMAND SIRENS ==================== -->
                <div id="homeFrontCommandAlertsTile" class="col-12 col-md-6 col-lg-2 col-xl-3">
                    <div id="pikudHeader" class="card table-card header-danger text-white mb-3">
                        <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#pikudBody" style="cursor: pointer">
                            <span><i class="fa-solid fa-bell me-2"></i>Home Front Command Alerts</span>
                            <div class="d-flex align-items-center gap-2">
                                <span id="liveClock" class="live-clock">00:00:00</span>
                                <i class="fa-solid fa-chevron-down collapse-icon"></i>
                            </div>
                        </div>
                    </div>

                    <div id="pikudBody" class="collapse show">
                        <div class="card table-responsive tile" id="pikud_haoref_feed" style="max-height: 93vh; overflow-y: auto;">
                            <table class=" table table-dark table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th width="10%">Time</th>
                                        <th width="5%">Type</th>
                                        <th>Location</th>
                                        <th>Zone</th>
                                    </tr>
                                </thead>
                                <tbody id="pikud_haoref_alerts" class="fw-medium"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ==================== ALERTS BY LOCATION + ZONE ==================== -->
                <div id="locationsZoneTile" class="col-12 col-md-6 col-lg-1 col-xl-2">
                    <!-- Locations -->
                    <div id="locationsHeader" class="card table-card header-danger text-white mb-3">
                        <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#locationsBody" style="cursor: pointer">
                            <span><i class="fa-solid fa-location-dot me-2"></i>Alert Locations</span>
                            <i class="fa-solid fa-chevron-down collapse-icon"></i>
                        </div>
                    </div>
                    <div id="locationsBody" class="collapse show">
                        <div class="card table-responsive tile" id="locations_feed" style="max-height: 43vh; overflow-y: auto;">
                            <table class=" table table-dark table-sm mb-0">
                                <tbody id="alerted_locations_counter"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Zones -->
                    <div id="zonesHeader" class="card table-card header-danger text-white mt-3 mb-3">
                        <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#zonesBody" style="cursor: pointer">
                            <span><i class="fa-solid fa-map me-2"></i>Alert Zones</span>
                            <i class="fa-solid fa-chevron-down collapse-icon"></i>
                        </div>
                    </div>
                    <div id="zonesBody" class="collapse show">
                        <div class="card table-responsive tile" id="zones_feed" style="max-height: 46vh; overflow-y: auto;">
                            <table class=" table table-dark table-sm mb-0">
                                <tbody id="alerted_zones_counter"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ==================== SUMMARY ==================== -->
                <div id="summaryLastAlertedTimesTile" class="col-12 col-md-6 col-lg-1 col-xl-2">
                    <!-- Alerts Summary -->
                    <div id="summaryHeader" class="card table-card header-primary text-white mb-3">
                        <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#summaryBody" style="cursor: pointer">
                            <span><i class="fa-solid fa-chart-pie me-2"></i>Alerts Summary</span>
                            <i class="fa-solid fa-chevron-down collapse-icon"></i>
                        </div>
                    </div>

                    <div id="summaryBody" class="collapse show">
                        <div class="card table-responsive tile">
                            <table class="table table-dark table-sm mb-0">
                                <tbody id="alerts_summary">
                                    <tr>
                                        <td><span>Total Alerts</span></td>
                                        <td class="text-end"><span id="totalAlertsCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <!-- These will be hidden unless one of them get triggered as the chances of them occurring are extremely low -->
                                    <!-- START -->
                                    <tr id="total_general_alerts_counter" style="display: none;">
                                        <td><span class="text-warning">Total General Alerts</span></td>
                                        <td class="text-end"><span id="generalAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="total_earthquake_alerts_counter" style="display: none;">
                                        <td><span class="text-warning">Total Earthquake Alerts</span></td>
                                        <td class="text-end"><span id="earthquakeAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="total_radiological_event_alerts_counter" style="display: none;">
                                        <td><span class="text-warning">Total Radiological Event Alerts</span></td>
                                        <td class="text-end"><span id="radiologicalEventAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="total_tsunami_alerts_counter" style="display: none;">
                                        <td><span class="text-warning">Total Tsunami Alerts</span></td>
                                        <td class="text-end"><span id="tsunamiAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="total_hazardous_materials_alerts_counter" style="display: none;">
                                        <td><span class="text-warning">Total Hazardous Materials Alerts</span></td>
                                        <td class="text-end"><span id="hazardousMaterialsAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="total_terrorist_infiltration_alerts_counter" style="display: none;">
                                        <td><span class="text-warning">Total Terrorist Infiltration Alerts</span></td>
                                        <td class="text-end"><span id="terroristInfiltrationAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <!-- END -->



                                    <tr>
                                        <td><span>Total Drone Alerts</span></td>
                                        <td class="text-end"><span id="droneAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr>
                                        <td><span>Total Rocket Alerts</span></td>
                                        <td class="text-end"><span id="rocketAlertCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr>
                                        <td><span>Drone Share</span></td>
                                        <td class="text-end"><span id="droneShareCounter" class="stat-number">0%</span></td>
                                    </tr>
                                    <tr>
                                        <td><span>Rocket Share</span></td>
                                        <td class="text-end"><span id="rocketShareCounter" class="stat-number">0%</span></td>
                                    </tr>
                                    <tr>
                                        <td><span>Total Locations</span></td>
                                        <td class="text-end"><span id="totalLocationsCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr>
                                        <td><span>Total Zones</span></td>
                                        <td class="text-end"><span id="totalZonesCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr>
                                        <td><span>Total Early Warnings (All)</span></td>
                                        <td class="text-end"><span id="totalEarlyWarningsAllCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="total_early_warnings_specific_counter" style="display: none">
                                        <td><span>Total Early Warnings (Specific)</span></td>
                                        <td class="text-end"><span id="totalEarlyWarningsSpecificCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="unmatched_cities_counter" style="display: none">
                                        <td><span>Total Unmatched Cities</span></td>
                                        <td class="text-end"><span id="totalUnmatchedCitiesCounter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="unmatched_cities" style="display: none">
                                        <td><span>Open Unmatched Cities</span></td>
                                        <td class="text-end">
                                            <i id="show_unmatched_cities" class="fa-solid fa-arrow-up-right-from-square fa-xl icon-btn text-danger" style="cursor: pointer" title="Show Unmatched Cities"></i>
                                        </td>
                                    </tr>
                                    <tr id="error_counter" style="display: none">
                                        <td><span>Total Errors</span></td>
                                        <td class="text-end"><span id="pikud_haoref_error_counter" class="stat-number">0</span></td>
                                    </tr>
                                    <tr id="error_message" style="display: none">
                                        <td><span>Open Error Messages</span></td>
                                        <td class="text-end">
                                            <i id="show_error_messages" class="fa-solid fa-arrow-up-right-from-square fa-xl text-danger" style="cursor: pointer" title="Show Error Messages"></i>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span>Test Mode</span></td>
                                        <td class="text-end">
                                            <i id="test_mode" class="fa-solid fa-play fa-xl text-light" title="Turn ON Test Mode"></i>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span>Fullscreen</span></td>
                                        <td class="text-end">
                                            <i id="fullscreen" class="fa-solid fa-expand fa-xl text-light" title="Enter Fullscreen"></i>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span>Settings</span></td>
                                        <td class="text-end">
                                            <i id="open_settings" class="fa-solid fa-gear fa-xl text-light" title="Open Settings"></i>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span>App Version</span></td>
                                        <td class="text-end"><span id="appVersion" class="stat-number"><%= appVersion %></span></td>
                                    </tr>
                                    <tr id="update_app_version" style="display: none">
                                        <td><span>App Update Available</span></td>
                                        <td class="text-end">
                                            <i class="fa-solid fa-cloud-arrow-up fa-xl text-warning" title="Update it on your server"></i>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>


                    <!-- Last Alerted Times -->
                    <div id="lastAlertedTimesHeader" class="card table-card header-danger text-white mt-3 mb-3">
                        <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#lastAlertedTimesBody" style="cursor: pointer">
                            <span><i class="fa-solid fa-clock me-2"></i>Last Alerted Times</span>
                            <i class="fa-solid fa-chevron-down collapse-icon"></i>
                        </div>
                    </div>

                    <div id="lastAlertedTimesBody" class="collapse show">
                        <div class="card table-responsive tile" id="last_alerted_times_feed" style="max-height: 46vh; overflow-y: auto;">
                            <table class=" table table-dark table-sm mb-0">
                                <tbody id="last_alerted_times">

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ==================== NEWS + MAP ==================== -->
                <div id="newsMapTile" class="col-12 col-md-12 col-lg-4 col-xl-5">
                    <!-- News -->
                    <div id="newsHeader" class="card table-card header-success text-white mb-3">
                        <div class="card-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#newsBody" style="cursor: pointer">
                            <span class="section-header"><i class="fa-solid fa-newspaper me-2"></i>News Updates</span>
                            <div class="d-flex align-items-center gap-2">
                                <select id="rssFeedSelector" class="form-select form-select-sm bg-dark text-white border-0" style="display: none"></select>
                                <i class="fa-solid fa-chevron-down collapse-icon"></i>
                            </div>
                        </div>
                    </div>

                    <div id="newsBody" class="collapse show">
                        <div class="card table-responsive tile" id="rss_feed" style="max-height: 25vh; overflow-y: auto;">
                            <table class="table table-dark table-sm mb-0">
                                <tbody id="rss_alerts"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Map -->
                    <div id="mapHeader" class="card table-card header-danger text-white mt-3 mb-3">
                        <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#mapBody" style="cursor: pointer">
                            <span><i class="fa-solid fa-map-location-dot me-2"></i>Map Alerts</span>
                            <i class="fa-solid fa-chevron-down collapse-icon"></i>
                        </div>
                    </div>

                    <div id="mapBody" class="collapse show">
                        <div class="card table-responsive tile overflow-hidden" style="border-radius: 16px">
                            <div id="map"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modals -->

        <!-- Early Warning Modal - Enter -->
        <div class="modal fade" id="earlyWarningModalEnter" tabindex="-1" aria-labelledby="earlyWarningModalEnterLabel">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content glass-modal bg-danger text-white border-0">
                    <!-- Header -->
                    <div class="modal-header border-0 px-4 pt-4 pb-3">
                        <h4 class="modal-title fw-semibold text-white" id="earlyWarningModalEnterLabel"><i class="fa-solid fa-circle-exclamation me-3 text-white"></i>Early Missile Warning Alert</h4>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body px-4 py-1">
                        <div class="glass-inner p-4 rounded-4">

                            <span class="text-white-50 small mb-3">Alerted at <strong id="earlyWarningOpenedAt"></strong></span>
                            &nbsp;&middot;&nbsp;
                            <span class="text-white-50 small mb-3">Estimated time before missile sirens: <strong id="earlyWarningCountdown"></strong></span>
                            <br /><br />
                            This message will disappear automatically when the threat is no longer active.
                            <br /><br />
                            <b>The following locations are affected:</b>
                            <br />

                            <div id="earlyWarningLocations" style="width: 100%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        </div>

        <!-- Early Warning Modal - Exit -->
        <div class="modal fade" id="earlyWarningModalExit" tabindex="-1" aria-labelledby="earlyWarningModalExitLabel">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content glass-modal bg-success text-white border-0">
                    <!-- Header -->
                    <div class="modal-header border-0 px-4 pt-4 pb-3">
                        <h4 class="modal-title fw-semibold text-white" id="earlyWarningModalExitLabel"><i class="fa-solid fa-circle-check me-3 text-white"></i>Safe To Exit Bomb Shelter</h4>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body px-4 py-1">
                        <div class="glass-inner p-4 rounded-4">
                            You can now exit the bomb shelter.
                            <br /><br />
                            This message will disappear automatically after 10 seconds.
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer border-0 px-4 pb-4">
                        <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Error Messages Modal -->
        <div class="modal fade" id="errorMessagesModal" tabindex="-1" aria-labelledby="errorMessagesModalLabel">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content glass-modal bg-dark text-white border-0">
                    <!-- Header -->
                    <div class="modal-header border-0 px-4 pt-4 pb-3">
                        <h4 class="modal-title fw-semibold text-white" id="errorMessagesModalLabel"><i class="fa-solid fa-circle-exclamation me-3"></i>Error Messages</h4>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body px-4 py-1">
                        <div class="glass-inner p-4 rounded-4">
                            Unique error messages received from the Pikud HaOref service.
                            <br /><br />
                            <ul id="pikud_haoref_error_messages" style="width: 100%"></ul>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer border-0 px-4 pb-4">
                        <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Unmatched Cities Modal -->
        <div class="modal fade" id="unmatchedCitiesModal" tabindex="-1" aria-labelledby="unmatchedCitiesModalLabel">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content glass-modal bg-dark text-white border-0">
                    <!-- Header -->
                    <div class="modal-header border-0 px-4 pt-4 pb-3">
                        <h4 class="modal-title fw-semibold text-white" id="unmatchedCitiesModalLabel"><i class="fa-solid fa-circle-exclamation me-3 text-white"></i>Unmatched Cities</h4>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body px-4 py-1">
                        <div class="glass-inner p-4 rounded-4">
                            These are the unmatched cities received from the Pikud HaOref service.
                            <br />
                            <br />
                            <ul id="unmatched_cities_messages" style="width: 100%"></ul>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer border-0 px-4 pb-4">
                        <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Settings Modal -->
        <div class="modal fade" id="settingsModal" tabindex="-1" aria-labelledby="settingsModalLabel">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content glass-modal bg-dark">
                    <!-- Header -->
                    <div class="modal-header border-0 px-4 pt-4 pb-3">
                        <h4 class="modal-title fw-semibold text-white" id="settingsModalLabel"><i class="fa-solid fa-sliders me-3 text-primary"></i>Settings</h4>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body px-4 py-1">
                        <div class="glass-inner p-4 rounded-4">
                            <table class="table table-dark table-borderless mb-0">
                                <tr>
                                    <td width="45%" class="align-middle">
                                        <span class="text-white fw-medium">City (Early Warning)</span>
                                    </td>
                                    <td>
                                        <input class="form-control" type="text" id="citySearch" autocomplete="off" placeholder="Type city name..." />

                                        <ul id="city_suggestions" class="list-group position-absolute w-100 mt-2 shadow-lg rounded-3 overflow-hidden" style="display: none; max-height: 320px; overflow-y: auto; z-index: 1060"></ul>
                                    </td>
                                    <td width="20%" class="text-end align-middle">
                                        <button class="btn btn-primary px-4 py-2 fw-semibold" id="saveCityButton"><i class="fa-solid fa-floppy-disk me-2"></i>Save</button>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="pt-3">
                                        <hr class="text-white" />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium">Pikud HaOref Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_pikud_scroll" checked />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium">Zones Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_zones_scroll" checked />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium">Locations Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_locations_scroll" checked />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium">Last Alerted Times Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_last_alerted_times_scroll" checked />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium">RSS Feed Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_rss_scroll" checked />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium">Early Warning Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_early_warning_scroll" checked />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium">Prevent Map Auto-Maximization</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_prevent_map_auto_maximization" />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium">Test Mode Type</span>
                                    </td>
                                    <td colspan="2">
                                        <select class="form-select" id="test_mode_type">
                                            <option value="alertByCity">Alert by City</option>
                                            <option value="alertByRegion">Alert by Region</option>
                                            <option value="earlyWarning">Early Warning</option>
                                            <option value="nonMissileUAV">Non-Missile / UAV</option>
                                        </select>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium">Dashboard Style</span>
                                    </td>
                                    <td colspan="2">
                                        <select class="form-select" id="css_style_theme">
                                            <option value="default">Command Center (Default)</option>
                                            <option value="graphite">Graphite Pro</option>
                                            <option value="tv_mode">TV Mode</option>
                                        </select>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer border-0 px-4 pb-4">
                        <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            // ==================== APPLICATION STATE ====================
            // Accumulator arrays — each entry is an object {location, counter} or {zone, counter}
            let alertsActive = false; // True while at least one active alert is ongoing (used to gate certain features until the first alert arrives)
            let allowMapAutoMaximization = true; // When true, the map will automatically maximize when a new location alert is received. Can be disabled in settings.
            let alertedLocations = []; // All unique locations that have received alerts this session
