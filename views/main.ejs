                    icon: "fa-plane-up text-orange"
                },
                earthQuake: {
                    text: "Earthquake Alert",
                    icon: "fa-house-chimney-crack text-general-alerts"
                },
                radiologicalEvent: {
                    text: "Radiological Alert",
