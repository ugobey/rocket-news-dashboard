                const fadeStep = 0.08;
                const interval = 50;
                const markerContent = marker.content;

                const fadeInterval = setInterval(() => {
                    opacity += fadeStep;
                    if (opacity >= 1) {
                        clearInterval(fadeInterval);
                        markerContent.style.opacity = '1';
                    } else {
                        markerContent.style.opacity = String(opacity);
                    }
                }, interval);
            }

