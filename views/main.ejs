<!DOCTYPE html>

<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%-title%>
    </title>

    <link href="/css/bootstrap-5.3.3/bootstrap.min.css" rel="stylesheet">

    <script src="/js/jquery-3.7.1.min.js"></script>
    <script src="/js/bootstrap-5.3.3/bootstrap.bundle.min.js"></script>
    <script src="/js/moment-2.30.1.min.js"></script>

    <style>
        :root {
            --bs-body-bg: #212529;
        }

        html {
            font-size: 13px;
        }

        body {
            background-color: #212529;
            color: #e9ecef;
        }

        .section-header {
            font-size: 1.1rem;
            font-weight: 600;
        }

        .alert-new {
            animation: highlightFade 5s forwards;
        }

        @keyframes highlightFade {
            0% {
                background-color: #fff3cd;
            }

            100% {
                background-color: transparent;
            }
        }

        .table th,
        .table td {
            vertical-align: middle;
        }

        .rss-feed {
            font-size: 0.95rem;
        }
    </style>

</head>

<body>

    <!-- MAIN CONTENT -->
    <div class="container-fluid p-2">
        <div class="row g-2">

            <!-- Pikud HaOref Alerts -->
            <div class="col-lg-3 col-md-6">
                <div class="card bg-danger text-white border-0 mb-2">
                    <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#pikudBody" style="cursor: pointer;">
                        Pikud HaOref Alerts
                    </div>
                </div>
                <div id="pikudBody" class="collapse show">
                    <div class="card bg-dark border-0 mb-2">
                        <table class="table table-sm table-dark table-striped mb-0">
                            <tbody id="pikud_haoref_alerts"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Alerts Summary + Alerted Locations -->
            <div class="col-lg-3 col-md-6">
                <!-- Summary -->
                <div class="card bg-success text-white border-0 mb-2">
                    <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#summaryBody" style="cursor: pointer;">
                        Alerts Summary
                    </div>
                </div>
                <div id="summaryBody" class="collapse show">
                    <div class="card bg-dark border-0 mb-2">
                        <table class="table table-sm table-dark mb-0">
                            <tbody id="alerts_summary">
                                <tr>
                                    <td width="20%">
                                        <span class="text-warning">Total Locations</span>
                                    </td>
                                    <td>
                                        <span id="totalLocationsCounter">0</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td width="20%">
                                        <span class="text-warning">Total Alerts</span>
                                    </td>
                                    <td>
                                        <span id="totalAlertsCounter">0</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td width="20%">
                                        <span class="text-warning">Drone Alerts</span>
                                    </td>
                                    <td>
                                        <span id="droneAlertCounter">0</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td width="20%">
                                        <span class="text-warning">Missile Alerts</span>
                                    </td>
                                    <td>
                                        <span id="missileAlertCounter">0</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td width="20%">
                                        <span class="text-warning">Total Early Warnings</span>
                                    </td>
                                    <td>
                                        <span id="totalEarlyWarningsCounter">0</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td width="20%">
                                        <span class="text-light">Test Alerts</span>
                                    </td>
                                    <td>
                                        <button id="test_mode" type="button" class="btn btn-primary btn-sm w-auto bg-light text-black border-0">Turn on Test Mode</button>
                                    </td>
                                </tr>
                                <tr id="error_counter" style="display:none;">
                                    <td width="20%">
                                        <span class="text-danger fw-bold">Total Errors</span>
                                    </td>
                                    <td>
                                        <span id="pikud_haoref_error_counter">0</span>
                                    </td>
                                </tr>
                                <tr id="error_message" style="display:none;">
                                    <td width="20%">
                                        <span class="text-danger fw-bold">Last Error Message</span>
                                    </td>
                                    <td>
                                        <span id="pikud_haoref_error_message"></span>
                                    </td>
                                </tr>

                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Alerted Locations -->
                <div class="card bg-primary text-white border-0 mb-2">
                    <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#locationsBody" style="cursor: pointer;">
                        Alerted Locations Counter
                    </div>
                </div>
                <div id="locationsBody" class="collapse show">
                    <div class="card bg-dark border-0 mb-2">
                        <table class="table table-sm table-dark table-striped mb-0">
                            <tbody id="alerted_locations_counter"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- News + Tzofar -->
            <div class="col">
                <!-- News -->
                <div class="card bg-secondary text-white border-0 mb-2">
                    <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#newsBody" style="cursor: pointer;">
                        News Updates
                        <select id="rssFeedSelector" class="form-select form-select-sm w-auto bg-dark text-white border-0" style="display: none;"></select>
                    </div>

                </div>
                <div id="newsBody" class="collapse show">
                    <div class="card bg-dark border-0 mb-2 rss-feed scrollable" style="max-height: 22vh; overflow-y: auto;">
                        <table class="table table-sm table-dark table-striped mb-0">
                            <tbody id="rss_alerts"></tbody>
                        </table>
                    </div>
                </div>

                <!-- Tzofar GPS -->
                <div class="card bg-danger text-white border-0 mb-2">
                    <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#tzofarBody" style="cursor: pointer;">
                        Tzofar GPS Alerts
                    </div>
                </div>
                <div id="tzofarBody" class="collapse show">
                    <div>
                        <iframe src="https://www.tzevaadom.co.il/en/" style="width:100%; height:1550px; border:none; border-radius: 6px;" title="Tzofar GPS Alerts"></iframe>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Early Warning Modal -->
    <div class="modal fade" id="earlyWarningModal" tabindex="-1" aria-labelledby="earlyWarningModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-danger text-white border-0">
                <div class="modal-header border-0">
                    <h5 class="modal-title" id="earlyWarningModalLabel">Early Warning Alert</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    There is an active early warning due to a ballistic missile launch.<br><br>
                    This message will disappear automatically when sirens sound or after 5 minutes.
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
    <!-- end content -->

    <script>
        async function ajaxHandler(service) {
            let response = "";

            $.ajax({
                url: "/ajax",
                type: "POST",
                data: {
                    "service": service,
                    "rssfeed": rssFeedSelected,
                    "testmode": testmode
                },
                async: false,
                dataType: "json",
                success: function (result) {
                    response = result;
                },
                error: function (XMLHttpRequest, textStatus, errorThrown) {
                    console.log(XMLHttpRequest, textStatus, errorThrown)
                }
            });

            return response;
        }

        setInterval(() => {
            $(".alertNewRow").removeClass("table-light");
            $(".alertNewRow").removeClass("alertNewRow");

            $(".rssNewRow").removeClass("table-light");
            $(".rssNewRow").removeClass("rssNewRow");
        }, 5000);

        const earlyWarningModal = new bootstrap.Modal('#earlyWarningModal');

        let alertedLocations = [];
        let missileAlertCounter = 0;
        let droneAlertCounter = 0;
        let totalEarlyWarningsCounter = 0;
        let earlyWarningActive = false;
        let testmode = false;

        $("#test_mode").on("click", function () {
            if (testmode) {
                testmode = false;

                $("#test_mode").text("Turn on Test Mode");
            } else {
                testmode = true;

                $("#test_mode").text("Turn off Test Mode");
            }
        });

        //Pikud HaOref service
        fetch('/json/cities.json')
            .then((response) => response.json())
            .then((data) => {
                const locationsJSON = data;

                const pikudHaorefInterval = 1000;
                const recentlyAlertedLocations = {};

                let pikudHaorefErrorCounter = 0;
                let pikudHaorefError = false;

                function getAlertTypeByCategory(type) {
                    switch (type) {
                        case "newsFlash":
                            return "Early Warning";
                        case "missiles":
                            return "Rocket Alert";
                        case "hostileAircraftIntrusion":
                            return "Drone Alert";
                        case "general":
                            return "General Alert";
                        case "earthQuake":
                            return "Earthquake Alert";
                        case "radiologicalEvent":
                            return "Radiological Alert";
                        case "tsunami":
                            return "Tsunami Alert";
                        case "hazardousMaterials":
                            return "Hazardous Materials Alert";
                        case "terroristInfiltration":
                            return "Terrorist Infiltration Alert";
                        case "missilesDrill":
                            return "Drill - Rocket Alert";
                        case "generalDrill":
                            return "Drill  - General Alert";
                        case "earthQuakeDrill":
                            return "Drill - Earthquake Alert";
                        case "radiologicalEventDrill":
                            return "Drill - Radiological Alert";
                        case "tsunamiDrill":
                            return "Drill - Tsunami Alert";
                        case "hostileAircraftIntrusionDrill":
                            return "Drill - Hostile Aircraft Alert";
                        case "hazardousMaterialsDrill":
                            return "Drill - Hazardous Materials";
                        case "terroristInfiltrationDrill":
                            return "Drill - Terrorist Infiltration Alert";
                        default:
                            return "Unknown Alert";
                    }
                }

                function extractNewLocations(alertLocations) {
                    const newLocations = [];
                    const now = Math.floor(Date.now() / 1000);

                    for (let location of alertLocations) {
                        if (!recentlyAlertedLocations[location] || recentlyAlertedLocations[location] < now - 60) {
                            newLocations.push(location);
                            recentlyAlertedLocations[location] = now;
                        }
                    }

                    return newLocations;
                }

                setInterval(() => {
                    if (earlyWarningActive) {
                        earlyWarningModal.hide();
                        earlyWarningActive = false;
                    }
                }, 300000);

                function updateAlertedLocation(location) {
                    const index = alertedLocations.findIndex(item => item.location === location);

                    if (index !== -1) {
                        alertedLocations[index].counter++;
                    } else {
                        alertedLocations.push({ location: location, counter: 1 });
                    }
                }

                const pikudHaorefPoll = async function () {
                    try {
                        setTimeout(pikudHaorefPoll, pikudHaorefInterval);

                        const alert = await ajaxHandler("pikud_haoref");

                        if (alert) {

                            window.alertsJSON = alert;

                            if (alert.error) {
                                pikudHaorefErrorCounter++

                                if (!pikudHaorefError) {
                                    pikudHaorefError = true;
                                    $("#error_counter, #error_message").show();
                                }

                                $("#pikud_haoref_error_counter").text(pikudHaorefErrorCounter);

                                if (alert.error.indexOf("Request failed with status code 403") > -1) {
                                    $("#pikud_haoref_error_message").text("403 Forbidden - Requires Israeli IP");
                                    console.log("Pikud HaOref Error: 403 Forbidden - Requires Israeli IP");
                                }
                                else {
                                    $("#pikud_haoref_error_message").text(alert.error);
                                    console.log("Pikud HaOref Error: " + alert.error);
                                }
                                return;
                            }



                            if (alert.length) {
                                console.log(alert[0]);
                                //console.log("Alert : ", alert[0]);
                                //console.log(JSON.stringify(alert));

                                const alertType = alert[0] && alert[0].type;

                                if (alertType === "newsFlash") {
                                    const instructions = alert[0].instructions;

                                    if (instructions === "האירוע הסתיים") {
                                        earlyWarningActive = false;
                                        earlyWarningModal.hide();
                                    } else {
                                        if (!earlyWarningActive) {
                                            totalEarlyWarningsCounter++
                                            $("#totalEarlyWarningsCounter").text(totalEarlyWarningsCounter);
                                        }

                                        earlyWarningActive = true;
                                        earlyWarningModal.show();
                                    }

                                } else if (alertType != "newsFlash") {
                                    earlyWarningModal.hide();

                                    const alertTypeText = getAlertTypeByCategory(alertType);
                                    const timeStamp = moment().format("h:mm:ss a");

                                    const locations = extractNewLocations(alert[0].cities);

                                    for (let i = 0; i < locations.length; i++) {
                                        const locationOriginal = locations[i];
                                        let location = locations[i];

                                        for (let c = 0; c < locationsJSON.length; c++) {
                                            if (locationsJSON[c].value === location) {
                                                location = locationsJSON[c].name_en;
                                                break;
                                            }
                                        }

                                        if (location) {
                                            if (alertType === "missiles" || alertType === "hostileAircraftIntrusion") {

                                                if (alertType === "missiles") {
                                                    missileAlertCounter++
                                                    $("#missileAlertCounter").text(missileAlertCounter);
                                                }
                                                else if (alertType === "hostileAircraftIntrusion") {
                                                    droneAlertCounter++
                                                    $("#droneAlertCounter").text(droneAlertCounter);
                                                }

                                                $("#totalAlertsCounter").text(missileAlertCounter + droneAlertCounter);
                                                updateAlertedLocation(location);

                                            }

                                            $("#pikud_haoref_alerts").prepend("<tr class='alertNewRow table-light'><td><font class='text-info'>" + alertTypeText + "</font></td><td>" + location + " (" + locationOriginal + ")</td><td><font class='text-warning'>" + timeStamp + "</font></td></tr>");
                                        }
                                    }

                                    if (alertType === "missiles" || alertType === "hostileAircraftIntrusion") {
                                        $("#alerted_locations_counter").html("");

                                        const sortalertedLocations = alertedLocations.toSorted((a, b) => b.counter - a.counter);

                                        for (let i = 0; i < sortalertedLocations.length; i++) {
                                            const location = sortalertedLocations[i].location
                                            const counter = sortalertedLocations[i].counter;

                                            $("#alerted_locations_counter").append("<tr><td><font class='text-info'>" + location + "</font></td><td>" + counter + "</td></tr>");
                                        }

                                        $("#totalLocationsCounter").text(sortalertedLocations.length);
                                    }

                                }
                            }
                        }
                    }
                    catch (error) {
                        console.error("Error in Pikud HaOref Polling:", error);
                    }
                };

                pikudHaorefPoll();
            })
            .catch((error) => {
                console.error('Error Fetching JSON File:', error);
            });


        //RSS service
        const getSelectOptionValues = [];
        let selectOptionsValuesCount = 0;
        let rssFeedSelected;
        let rssFeedPollStarted = false;
        const newsArray = [];
        let rssInterval = 30000;

        const rssFeeds = [
            { codename: "RSSarutz7", realname: "Arutz 7" },
            { codename: "RSSbnn", realname: "BNN" },
            { codename: "RSSjerusalemPost", realname: "JPost" },
            { codename: "RSSynet", realname: "Ynet" }
        ];

        for (let i = 0; i < rssFeeds.length; i++) {
            const codename = rssFeeds[i].codename;
            const realname = rssFeeds[i].realname;

            $("#rssFeedSelector").append("<option value='" + codename + "'>" + realname + "</option>");
        };

        $("#rssFeedSelector option").each(function () {
            getSelectOptionValues.push($(this).val())
        });

        function getRealName(codename) {
            const feed = rssFeeds.find(feed => feed.codename === codename);
            return feed.realname;
        };

        const rssPoll = async function () {

            rssFeedSelected = getSelectOptionValues[selectOptionsValuesCount];
            $("#rssFeedSelector").val(rssFeedSelected);
            selectOptionsValuesCount++;

            if (selectOptionsValuesCount === getSelectOptionValues.length) {
                selectOptionsValuesCount = 0;
            }

            setTimeout(rssPoll, rssInterval);

            if (rssFeedSelected) {
                let reversedArray = [];

                const news = await ajaxHandler("rss", rssFeedSelected);

                if (news) {
                    if (news.error) {
                        console.log(news.error);
                        $("#rss_alerts").prepend("<tr><td>" + news.error + "</td></tr>");
                        return;
                    }

                    news.feed.items.forEach((item) => {
                        reversedArray.push({ pubDate: item.pubDate, title: item.title });
                    });

                    reversedArray = reversedArray.reverse();

                    reversedArray.forEach((item) => {
                        const publishDate = moment(item.pubDate).format("h:mm:ss a");
                        const publishDay = moment(item.pubDate).format("MMM Do YYYY");
                        const currentDay = moment().format("MMM Do YYYY");

                        const today = moment();
                        const yesterday = moment(today.startOf("day")).set(
                            "date",
                            today.get("date") - 1
                        );
                        const yesterDay = yesterday.format("MMM Do YYYY");

                        if (publishDay === currentDay) {
                            if (!newsArray.includes(publishDate + " : " + item.title)) {
                                newsArray.push(publishDate + " : " + item.title);

                                $("#rss_alerts").prepend("<tr class='rssNewRow table-light'><td width='7%'><font class='text-warning'>" + publishDate + "</font></td><td width='5%'><font class='text-secondary'>" + getRealName(rssFeedSelected) + "</font></td><td>" + item.title + "</td></tr>");
                            }
                        }
                    });
                }
            }
        };

        rssPoll();

    </script>

</body>

</html>