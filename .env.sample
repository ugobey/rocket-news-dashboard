# Rocket News Dashboard environment variables
# Copy this file to .env and adjust values

# Port where app listens (optional; defaults to config.json webServerPort)
PORT=8080

# If running outside Israel and you need proxy for API access
PROXY_URL=http://your-proxy.example.com:2887

# Google Maps API key for map views
GOOGLE_MAPS_API_KEY=YOUR_API_KEY

# Optional: override config.json repo value
GIT_REPO=git@github.com:ugobey/rocket-news-dashboard.git
