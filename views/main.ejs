                                <tr>
                                    <td class="align-middle">
                                        <span class="text-white fw-medium">Last Alerted Times Auto-Scroll</span>
                                    </td>
                                    <td colspan="2">
                                        <input class="form-check-input" type="checkbox" id="toggle_last_alerted_times_scroll" checked />
                                    </td>
