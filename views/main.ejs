                                                </td>
                                                <td width="20%" class="text-end align-middle">
                                                    <button class="btn btn-primary px-4 py-2 fw-semibold" id="saveCityButton"><i class="fa-solid fa-floppy-disk me-2"></i>Save</button>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>

                                <!-- Footer -->
                                <div class="modal-footer border-0 px-4 pb-4">
                                    <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">Close</button>
                                </div>
                            </div>
                        </div>
