                    <script>
                function updateClock () {
                    const now = new Date();
                    const h = String(now.getHours()).padStart(2, '0');
                    const m = String(now.getMinutes()).padStart(2, '0');
                    const s = String(now.getSeconds()).padStart(2, '0');

                    const timeString = `${h}:${m}:${s}`;

                    // Update header clock
                    const clockHeader = document.getElementById('liveClock');
                    if (clockHeader) clockHeader.textContent = timeString;
                }

                updateClock();
                setInterval(updateClock, 1000);

                function fitTzofarBodyToViewport () {
                    const tzofarBody = $('#tzofarBody');
                    if (!tzofarBody || !tzofarBody.hasClass('show')) {
                        return;
                    }

                    const tzofarMapFrame = $('#tzofarMapFrame')[0];
                    const tzofarCard = tzofarBody.find('.card')[0];
                    const rect = tzofarBody[0].getBoundingClientRect();
                    const viewportBottomGap = 15;
                    const minHeight = 280;
                    const availableHeight = Math.max(minHeight, Math.floor(window.innerHeight - rect.top - viewportBottomGap));

                    // Keep this section growing downward to fill the visible viewport.
                    tzofarBody.css('height', `${availableHeight}px`);

                    if (tzofarCard) {
                        $(tzofarCard).css('height', '100%');
                    }

                    if (tzofarMapFrame) {
                        $(tzofarMapFrame).css('height', '100%');
                    }
                }

                let fitTzofarRafId = null;

                function scheduleFitTzofarBodyToViewport () {
                    if (fitTzofarRafId !== null) {
                        cancelAnimationFrame(fitTzofarRafId);
                    }

                    fitTzofarRafId = requestAnimationFrame(() => {
                        fitTzofarRafId = null;
                        fitTzofarBodyToViewport();
                    });
                }

                const tzofarBodyElement = $('#tzofarBody');
                const newsBodyElement = $('#newsBody');

                if (tzofarBodyElement.length) {
                    tzofarBodyElement.on('shown.bs.collapse', scheduleFitTzofarBodyToViewport);
                    tzofarBodyElement.on('hidden.bs.collapse', () => {
                        $(tzofarBodyElement).css('height', '');
                    });
                }

                if (newsBodyElement.length) {
                    newsBodyElement.on('shown.bs.collapse', scheduleFitTzofarBodyToViewport);
                    newsBodyElement.on('hidden.bs.collapse', scheduleFitTzofarBodyToViewport);

                    if (typeof ResizeObserver !== 'undefined') {
                        const newsBodyResizeObserver = new ResizeObserver(() => {
                            scheduleFitTzofarBodyToViewport();
                        });

                        newsBodyResizeObserver.observe(newsBodyElement[0]);
                    } else {
                        const rssAlertsElement = $('#rss_alerts')[0];

                        if (rssAlertsElement) {
                            const newsBodyMutationObserver = new MutationObserver(() => {
                                scheduleFitTzofarBodyToViewport();
                            });

                            newsBodyMutationObserver.observe(rssAlertsElement, {
                                childList: true,
                                subtree: true
                            });
                        }
                    }
                }

                $(window).on('resize', scheduleFitTzofarBodyToViewport);
                $(window).on('load', scheduleFitTzofarBodyToViewport);

                scheduleFitTzofarBodyToViewport();

                setInterval(() => {
                    if (pikud_haoref_alerts.children.length > 500) {
                        $('#pikud_haoref_alerts tr:last').remove();
                    }
                }, 1000);

                setInterval(() => {
                    $(".alertNewRow").removeClass("table-light");
                    $(".alertNewRow").removeClass("alertNewRow");

                    $(".rssNewRow").removeClass("table-light");
                    $(".rssNewRow").removeClass("rssNewRow");
                }, 5000);

                async function ajaxHandler (service, rssFeedURL) {
                    return new Promise((resolve) => {
                        $.ajax({
                            url: "/ajax",
                            type: "POST",
                            data: {
                                "service": service,
                                "rssfeed": rssFeedURL,
                                "testmode": testmode
                            },
                            async: true,
                            dataType: "json",
                            success: function (result) {
                                resolve(result);
                            },
                            error: function (XMLHttpRequest, textStatus, errorThrown) {
                                console.log(XMLHttpRequest, textStatus, errorThrown);
                            }
                        });
                    });
                }

                const earlyWarningModalEnter = new bootstrap.Modal('#earlyWarningModalEnter');
                const earlyWarningModalExit = new bootstrap.Modal('#earlyWarningModalExit');
                const errorMessagesModal = new bootstrap.Modal('#errorMessagesModal');
                const unmatchedCitiesModal = new bootstrap.Modal('#unmatchedCitiesModal');
                const settingsModal = new bootstrap.Modal('#settingsModal');

                let alertedLocations = [];
                let alertedZones = [];
                let errorLogs = [];
                let unmatchedCitiesLogs = [];
                let earlyWarningLocations = [];

                let rocketAlertCounter = 0;
                let droneAlertCounter = 0;
                let totalEarlyWarningsAllCounter = 0;
                let totalEarlyWarningsSpecificCounter = 0;
                let pikudHaorefErrorCounter = 0;
                let totalUnmatchedCitiesCounter = 0;

                let pikudHaorefError = false;
                let unmatchedCitiesFlag = false;
                let earlyWarningActive = false;
                let testmode = false;

                const pikudHaorefInterval = 1000;
                const recentlyAlertedLocations = {};

                $("#test_mode").on("click", function () {
                    if (testmode) {
                        testmode = false;

                        $("#test_mode").attr("title", "Turn on Test Mode");
                        $("#test_mode").removeClass("fa-toggle-on active").addClass("fa-toggle-off");
                    } else {
                        testmode = true;

                        $("#test_mode").attr("title", "Turn off Test Mode");
                        $("#test_mode").removeClass("fa-toggle-off text-muted").addClass("fa-toggle-on active");
                    }
                });

                $("#show_error_messages").on("click", function () {
                    errorMessagesModal.show();
                });

                $("#show_unmatched_cities").on("click", function () {
                    unmatchedCitiesModal.show();
                });

                $("#open_settings").on("click", function () {
                    const savedCity = localStorage.getItem("earlyWarningCity");
                    if (savedCity) {
                        $("#citySearch").val(savedCity);
                    }
                    settingsModal.show();
                });

                $("#saveCityButton").on("click", function () {
                    const city = $("#citySearch").val().trim();

                    if (city) {
                        localStorage.setItem("earlyWarningCity", city);
                    } else {
                        localStorage.removeItem("earlyWarningCity");
                    }

                    settingsModal.hide();
                });

                const alertTypeMap = {
                    newsFlash: {
                        text: "Early Warning",
                        icon: "/icons/warning.png"
                    },
                    missiles: {
                        text: "Rocket Alert",
                        icon: "/icons/rocket.png"
                    },
                    hostileAircraftIntrusion: {
                        text: "Drone Alert",
                        icon: "/icons/uav.png"
                    },
                    earthQuake: {
                        text: "Earthquake Alert",
                        icon: "/icons/earthquake.png"
                    },
                    radiologicalEvent: {
                        text: "Radiological Alert",
                        icon: "/icons/radiological.png"
                    },
                    tsunami: {
                        text: "Tsunami Alert",
                        icon: "/icons/tsunami.png"
                    },
                    hazardousMaterials: {
                        text: "Hazardous Materials Alert",
                        icon: "/icons/hazardous.png"
                    }
                };

                function getAlertDetailsByCategory (type) {
                    return alertTypeMap[type] || null;
                }

                function extractNewLocations (alertLocations) {
                    const newLocations = [];
                    const now = Math.floor(Date.now() / 1000);

                    for (let location of alertLocations) {
                        if (!recentlyAlertedLocations[location] || recentlyAlertedLocations[location] < now - 60) {
                            newLocations.push(location);
                            recentlyAlertedLocations[location] = now;
                        }
                    }

                    return newLocations;
                }

                function updateAlertedLocation (location) {
                    const index = alertedLocations.findIndex(item => item.location === location);

                    if (index !== -1) {
                        alertedLocations[index].counter++;
                    } else {
                        alertedLocations.push({
                            location: location,
                            counter: 1
                        });
                    }
                }

                function updateAlertedZone (zone) {
                    const index = alertedZones.findIndex(item => item.zone === zone);

                    if (index !== -1) {
                        alertedZones[index].counter++;
                    } else {
                        alertedZones.push({
                            zone: zone,
                            counter: 1
                        });
                    }
                }

                //Pikud HaOref service
                const locationsJSON = <%- cities %>;

                const input = document.getElementById('citySearch');
                const suggestionsList = document.getElementById('city_suggestions');

                input.addEventListener('input', function () {
                    const query = this.value.toLowerCase().trim();

                    // Clear previous suggestions
                    suggestionsList.innerHTML = '';

                    if (query.length === 0) {
                        suggestionsList.style.display = 'none';
                        return;
                    }

                    // Filter JSON data
                    const filtered = locationsJSON.filter(city =>
                        city.name_en.toLowerCase().includes(query)
                    );

                    if (filtered.length === 0) {
                        suggestionsList.style.display = 'none';
                        return;
                    }

                    // Render suggestions
                    filtered.forEach(city => {
                        const li = document.createElement('li');
                        li.className = 'list-group-item list-group-item-action bg-light text-dark border-secondary';
                        li.innerHTML = `<strong>${city.name_en}</strong>`;

                        // Click to select
                        li.addEventListener('click', () => {
                            input.value = city.name_en;
                            suggestionsList.style.display = 'none';
                        });

                        suggestionsList.appendChild(li);
                    });

                    suggestionsList.style.display = 'block';
                });

                // Hide suggestions when clicking outside
                document.addEventListener('click', (e) => {
                    if (!e.target.closest('.position-relative')) {
                        suggestionsList.style.display = 'none';
                    }
                });

                const locationMap = Object.fromEntries(
                    locationsJSON.map(loc => [loc.value, {
                        name_en: loc.name_en,
                        zone: loc.zone,
                        zone_en: loc.zone_en,
                        lng: loc.lng,
                        lat: loc.lat,
                        countdown: loc.countdown
                    }])
                );

                const pikudHaorefPoll = async function () {
                    try {
                        setTimeout(pikudHaorefPoll, pikudHaorefInterval);

                        const alert = await ajaxHandler("pikud_haoref");

                        if (alert) {

                            window.alertsJSON = alert;

                            if (alert.error) {
                                pikudHaorefErrorCounter++

                                if (!pikudHaorefError) {
                                    pikudHaorefError = true;
                                    $("#error_counter, #error_message").show();
                                }

                                $("#pikud_haoref_error_counter").text(pikudHaorefErrorCounter);

                                if (!errorLogs.includes(alert.error)) {
                                    errorLogs.push(alert.error);

                                    if (alert.error.indexOf("Request failed with status code 403") > -1) {
                                        $("#pikud_haoref_error_messages").prepend("<li>403 Forbidden - Requires Israeli IP</li>");
                                    } else {
                                        $("#pikud_haoref_error_messages").prepend("<li>" + alert.error + "</li>");
                                    }
                                }

                                console.log("Pikud HaOref Error: " + alert.error);
                                return;
                            }

                            if (alert.length) {
                                const alertType = alert[0] && alert[0].type;

                                if (alertType === "newsFlash") {
                                    const instructions = alert[0].instructions;

                                    const earlyWarningCity = localStorage.getItem("earlyWarningCity") || "undefined";

                                    if (instructions === "האירוע הסתיים") {
                                        if (earlyWarningActive) {
                                            if (!earlyWarningModalExit._isShown) {
                                                earlyWarningModalExit.show();
                                            }

                                            setTimeout(() => {
                                                if (earlyWarningModalExit._isShown) {
                                                    earlyWarningModalExit.hide();
                                                }
                                            }, 30000);
                                        }

                                        earlyWarningLocations = [];
                                        earlyWarningActive = false;
                                        $("#earlyWarningLocations").text("");

                                        if (earlyWarningModalEnter._isShown) {
                                            earlyWarningModalEnter.hide();
                                        }
                                    } else {
                                        const checkIfCityAffected = alert[0].cities.map(city => locationMap[city]?.name_en).includes(earlyWarningCity);

                                        if (!earlyWarningActive) {
                                            if (checkIfCityAffected) {
                                                totalEarlyWarningsSpecificCounter++
                                                $("#totalEarlyWarningsSpecificCounter").text(totalEarlyWarningsSpecificCounter);
                                                $("#total_early_warnings_specific_counter").show();
                                            }

                                            totalEarlyWarningsAllCounter++
                                            $("#totalEarlyWarningsAllCounter").text(totalEarlyWarningsAllCounter);
                                        }

                                        earlyWarningActive = true;

                                        if (earlyWarningModalExit._isShown) {
                                            earlyWarningModalExit.hide();
                                        }

                                        if (!earlyWarningLocations.includes(alert[0].cities.join(","))) {
                                            earlyWarningLocations.push(alert[0].cities.join(","));

                                            $("#earlyWarningLocations").append(alert[0].cities.map(city => locationMap[city]?.name_en || city).join(", ") + "<br /><br />");
                                        }

                                        if (!earlyWarningModalEnter._isShown) {
                                            earlyWarningModalEnter.show();
                                        }
                                    }

                                } else if (alertType != "newsFlash") {
                                    earlyWarningLocations = [];
                                    earlyWarningActive = false;
                                    $("#earlyWarningLocations").text("");

                                    if (earlyWarningModalEnter._isShown) {
                                        earlyWarningModalEnter.hide();
                                    }

                                    if (earlyWarningModalExit._isShown) {
                                        earlyWarningModalExit.hide();
                                    }

                                    const alertTypeDetails = getAlertDetailsByCategory(alertType);

                                    if (alertTypeDetails) {
                                        const alertTypeText = alertTypeDetails.text;
                                        const alertTypeIcon = alertTypeDetails.icon;
                                        const timeStamp = moment().format("HH:mm:ss");

                                        const locations = extractNewLocations(alert[0].cities);

                                        for (let i = 0; i < locations.length; i++) {
                                            const locationOriginal = locations[i];

                                            const locationKey = locations[i].replace("''", "'");
                                            const location = locationMap[locationKey]?.name_en || locationOriginal;
                                            const zone = locationMap[locationKey]?.zone || "Unknown";
                                            const zone_en = locationMap[locationKey]?.zone_en || "Unknown";
                                            const lat = locationMap[locationKey]?.lat || "";
                                            const lng = locationMap[locationKey]?.lng || "";

                                            if (location) {
                                                if (alertType === "missiles") {
                                                    rocketAlertCounter++
                                                    $("#rocketAlertCounter").text(rocketAlertCounter);
                                                } else if (alertType === "hostileAircraftIntrusion") {
                                                    droneAlertCounter++
                                                    $("#droneAlertCounter").text(droneAlertCounter);
                                                }

                                                $("#totalAlertsCounter").text(rocketAlertCounter + droneAlertCounter);

                                                updateAlertedLocation(location);
                                                updateAlertedZone(zone_en);

                                                if (zone_en === "Unknown") {

                                                    console.log("Unmatched location:", alert[0]);

                                                    totalUnmatchedCitiesCounter++;
                                                    $("#totalUnmatchedCitiesCounter").text(totalUnmatchedCitiesCounter);

                                                    if (!unmatchedCitiesLogs.includes(location)) {
                                                        unmatchedCitiesLogs.push(location);
                                                        $("#unmatched_cities_messages").prepend("<li>" + location + "</li>");
                                                    }

                                                    if (!unmatchedCitiesFlag) {
                                                        unmatchedCitiesFlag = true;
                                                        $("#unmatched_cities_counter, #unmatched_cities").show();
                                                    }
                                                }

                                                $("#pikud_haoref_alerts").prepend(`
                                                    <tr class="animate__animated animate__fadeInDown animate__faster alertNewRow table-light">
                                                        <td><font class='text-warning'>${timeStamp}</font></td>
                                                        <td><img src="${alertTypeIcon}" style="width:20px; height:20px;" title="${alertTypeText}"></td>
                                                        <td><a href="https://www.google.com/maps/search/${lat},${lng}" target="_blank">${location}</a></td>
                                                        <td>${zone_en}</td>
                                                    </tr>
                                                `);
                                            }
                                        }

                                        if (alertType === "missiles" || alertType === "hostileAircraftIntrusion") {
                                            //Update Alerted Locations Counter
                                            $("#alerted_locations_counter").html("");

                                            const sortalertedLocations = alertedLocations.toSorted((a, b) => {
                                                // First compare by counter (descending)
                                                if (b.counter !== a.counter) {
                                                    return b.counter - a.counter;
                                                }

                                                // If counters are equal → compare locations alphabetically (ascending)
                                                return a.location.localeCompare(b.location);
                                            });

                                            for (let i = 0; i < sortalertedLocations.length; i++) {
                                                const location = sortalertedLocations[i].location
                                                const counter = sortalertedLocations[i].counter;

                                                $("#alerted_locations_counter").append(`
                                                    <tr>
                                                        <td width="95%"><font class='text-white'>${location}</font></td>
                                                        <td>${counter}</td>
                                                    </tr>
                                                `);
                                            }

                                            $("#totalLocationsCounter").text(sortalertedLocations.length);

                                            //Update Alerted Zones Counter
                                            $("#alerted_zones_counter").html("");

                                            const sortalertedZones = alertedZones.toSorted((a, b) => {
                                                // First compare by counter (descending)
                                                if (b.counter !== a.counter) {
                                                    return b.counter - a.counter;
                                                }

                                                // If counters are equal → compare zones alphabetically (ascending)
                                                return a.zone.localeCompare(b.zone);
                                            });

                                            for (let i = 0; i < sortalertedZones.length; i++) {
                                                const zone = sortalertedZones[i].zone
                                                const counter = sortalertedZones[i].counter;

                                                $("#alerted_zones_counter").append(`
                                                    <tr>
                                                        <td width="95%"><font class='text-white'>${zone}</font></td>
                                                        <td>${counter}</td>
                                                    </tr>
                                                `);
                                            }

                                            $("#totalZonesCounter").text(sortalertedZones.length);
                                        }

                                    }
                                }
                            }
                        }
                    } catch (error) {
                        console.error("Error in Pikud HaOref Polling:", error);
                    }
                };

                pikudHaorefPoll();



                //RSS service
                const newsArray = [];
                const rssInterval = 10000;
                let currentRssFeedIndex = 0;

                const rssFeeds = [{
                        codename: "RSSarutz7",
                        realname: "Arutz 7",
                        url: "https://www.israelnationalnews.com/Rss.aspx"
                    },
                    {
                        codename: "RSSbnn",
                        realname: "BNN",
                        url: "https://www.bernie.news/api/news/rss"
                    },
                    {
                        codename: "RSSjerusalemPost",
                        realname: "JPost",
                        url: "https://www.jpost.com/rss/rssfeedsfrontpage.aspx"
                    },
                    {
                        codename: "RSSynet",
                        realname: "Ynet",
                        url: "https://www.ynet.co.il/Integration/StoryRss3082.xml"
                    }
                ];


                function getRealName (codename) {
                    const feed = rssFeeds.find(feed => feed.codename === codename);
                    return feed.realname;
                };

                const rssPoll = async function () {

                    const rssFeedCodeName = rssFeeds[currentRssFeedIndex].codename;
                    const rssFeedURL = rssFeeds[currentRssFeedIndex].url;

                    currentRssFeedIndex++;

                    if (currentRssFeedIndex === rssFeeds.length) {
                        currentRssFeedIndex = 0;
                    }

                    setTimeout(rssPoll, rssInterval);

                    const news = await ajaxHandler("rss", rssFeedURL);

                    if (news && !news.error) {

                        let reversedArray = [];

                        news.feed.items.forEach((item) => {
                            reversedArray.push({
                                published: item.published,
                                title: item.title,
                                idpublished: item.id,
                                url: item.url
                            });
                        });

                        reversedArray = reversedArray.reverse();

                        reversedArray.forEach((item) => {
                            const published = item.published;
                            const timeStamp = moment().format("HH:mm");

                            if (!newsArray.includes(published)) {
                                newsArray.push(published);

                                $("#rss_alerts").prepend(`
                                    <tr class="animate__animated animate__fadeInDown animate__faster rssNewRow table-light">
                                        <td width="5%"><font class="text-warning">${timeStamp}</font></td>
                                        <td width="6%"><font class="text-info">${getRealName(rssFeedCodeName)}</font></td>
                                        <td><a href="${item.url}" target="_blank">${item.title}</a></td>
                                    </tr>
                                `);
                            }
                        });
                    }

                };

                rssPoll();

                async function checkAppVersion () {
                    try {
                        const versionCheck = await ajaxHandler("version_check");

                        if (versionCheck && versionCheck.updateAvailable) {
                            const latestVersion = versionCheck.latestVersion;

                            $("#update_app_version").show();
                        } else {
                            $("#update_app_version").hide();
                        }
                    } catch (error) {
                        console.error("Error checking app version:", error);
                    }
                }

                checkAppVersion();

                setInterval(() => {
                    checkAppVersion();
                }, 600000); // Check every 10 minutes

                    </script>
                </body>

                </html>
