                                                    </td>
                                                </tr>
                                                <tr id="error_counter" style="display: none">
                                                    <td><span class="text-violet-400">Total Errors</span></td>
                                                    <td class="text-end"><span id="pikud_haoref_error_counter" class="stat-number">0</span></td>
                                                </tr>
                                                <tr id="error_message" style="display: none">
                                                    <td><span class="text-violet-400">Open Error Messages</span></td>
                                                    <td class="text-end">
                                                        <i id="show_error_messages" class="fa-solid fa-arrow-up-right-from-square fa-xl icon-btn text-danger" style="cursor: pointer" title="Show Error Messages"></i>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td><span class="text-light">Test Mode</span></td>
                                                    <td class="text-end">
                                                        <i id="test_mode" class="fa-solid fa-toggle-off fa-xl icon-btn" style="cursor: pointer; transition: all 0.3s ease" title="Turn ON Test Mode"></i>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td><span class="text-light">Settings</span></td>
                                                    <td class="text-end">
                                                        <i id="open_settings" class="fa-solid fa-gear fa-xl icon-btn text-light" style="cursor: pointer; transition: all 0.3s ease" title="Open Settings"></i>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td><span class="text-violet-400">App Version</span></td>
                                                    <td class="text-end"><span id="appVersion" class="stat-number"><%= appVersion %></span></td>
