            //   rssFeedURL - RSS feed URL forwarded to the server (only used when service='rss')
            // The current testmode flag is always sent so the server can return mock data when needed.
            async function ajaxHandler (service, rssFeedURL) {
                return new Promise((resolve, reject) => {
                    const requestBody = new URLSearchParams({
                        service: service,
                        rssfeed: rssFeedURL || "",
                        testmode: testmode || "" // Tells the server to use hardcoded test data
                    });

                    fetch("/ajax", {
                            method: "POST",
                            body: requestBody
                        })
                        .then(async (response) => {
                            if (!response.ok) {
                                const responseText = await response.text().catch(() => "");
                                const requestLike = {
                                    status: response.status,
                                    statusText: response.statusText,
                                    responseText: responseText
                                };
                                const textStatus = response.statusText || "error";
                                const errorThrown = response.statusText || `HTTP ${response.status}`;

                                console.log(requestLike, textStatus, errorThrown);
                                reject(errorThrown || textStatus || "Fetch error");
                                return;
                            }

                            const result = await response.json();
                            resolve(result); // Resolve with the parsed JSON response
                        })
                        .catch((error) => {
                            const textStatus = error?.name || "error";
                            const errorThrown = error?.message || textStatus;

                            console.log(error, textStatus, errorThrown);
                            reject(errorThrown || textStatus || "Fetch error"); // Reject with an error message (try to get the most specific one available)
                        });
