                <!DOCTYPE html>

                <!DOCTYPE html>
                <html lang="en">

                <head>
                    <meta charset="UTF-8" />
                    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
                    <title><%-title%></title>

                    <link href="/css/bootstrap-5.3.3/bootstrap.min.css" rel="stylesheet" />
                    <link href="/css/animate.min.css" rel="stylesheet" />
                    <link href="/fonts/fontawesome-free-7.2.0/css/all.min.css" rel="stylesheet" />

                    <script src="/js/jquery-3.7.1.min.js"></script>
                    <script src="/js/bootstrap-5.3.3/bootstrap.bundle.min.js"></script>
                    <script src="/js/moment-2.30.1.min.js"></script>

                    <style>
                :root {
                    --primary: #0ea5e9;
                    --danger: #ef4444;
                    --success: #22c55e;
                    --warning: #eab308;
                    --glass: rgba(255, 255, 255, 0.06);
                    --glass-border: rgba(255, 255, 255, 0.12);
                }

                html {
                    font-size: 14px;
                }

                body {
                    background: linear-gradient(135deg, #0f172a 0%, #1e2937 100%);
                    color: #e2e8f0;
                    font-family: "Segoe UI", system-ui, sans-serif;
                    min-height: 100vh;
                }

                /* Remove underline and color change from all hyperlinks */
                a {
                    color: inherit;
                    /* Keeps current text color */
                    text-decoration: none;
                    /* Removes underline */
                    transition: color 0.2s ease;
                }

                a:hover {
                    color: inherit;
                    /* Prevents color change on hover */
                    text-decoration: none;
                }

                /* Optional: If you want a subtle hover effect (recommended for better UX) */
                a:hover {
                    opacity: 0.85;
                    /* Light fade on hover instead of color change */
                }

                .card {
                    background: var(--glass);
                    backdrop-filter: blur(20px);
                    border: 1px solid var(--glass-border);
                    border-radius: 20px;
                    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.35);
                    overflow: hidden;
                    /* ← Important */
                    transition: all 0.3s ease;
                }

                .card:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.45);
                }

                .card-header {
                    border-bottom: 1px solid var(--glass-border);
                    padding: 16px 20px;
                    font-weight: 600;
                    font-size: 1.07rem;
                    border-radius: 20px 20px 0 0 !important;
                }

                /* ==================== TABLE FIXES ==================== */
                .table-card {
                    border-radius: 20px;
                    overflow: hidden;
                }

                .table {
                    margin-bottom: 0;
                    border-collapse: separate;
                    border-spacing: 0;
                }

                .table thead tr {
                    background: rgba(0, 0, 0, 0.4);
                }

                .table th {
                    color: #94a3b8;
                    font-weight: 500;
                    text-transform: uppercase;
                    font-size: 0.73rem;
                    letter-spacing: 0.6px;
                    padding: 14px 12px;
                    border: none;
                    background: rgba(0, 0, 0, 0.3);
                }

                .table td {
                    padding: 11px 12px;
                    border-top: 1px solid rgba(255, 255, 255, 0.06);
                    border-bottom: none;
                    vertical-align: middle;
                }

                /* Round the table corners properly */
                .table tbody tr:first-child td:first-child {
                    border-top-left-radius: 16px;
                }

                .table tbody tr:first-child td:last-child {
                    border-top-right-radius: 16px;
                }

                .table tbody tr:last-child td:first-child {
                    border-bottom-left-radius: 16px;
                }

                .table tbody tr:last-child td:last-child {
                    border-bottom-right-radius: 16px;
                }

                .table-dark tr:hover {
                    background: rgba(255, 255, 255, 0.055) !important;
                }

                /* Colored headers */
                /*
                .header-danger {
                    background: linear-gradient(90deg, #7f1d1d, #b91c1c);
                }

                .header-primary {
                    background: linear-gradient(90deg, #1e40af, #1e3a8a);
                }

                .header-success {
                    background: linear-gradient(90deg, #166534, #15803d);
                }
                */

                .header-danger {
                    background: #b91c1c;
                }

                .header-primary {
                    background: #1e3a8a;
                }

                .header-success {
                    background: #15803d;
                }

                .live-clock {
                    background: rgba(0, 0, 0, 0.5);
                    padding: 6px 14px;
                    border-radius: 10px;
                    font-size: 0.77rem;
                    letter-spacing: 1px;
                }

                .stat-number {
                    font-size: 1.4rem;
                    font-weight: 700;
                    color: #f8fafc;
                }

                .modal-content {
                    background: #1e2937;
                    border: 1px solid var(--glass-border);
                    border-radius: 20px;
                }

                .rss-feed {
                    max-height: 38vh;
                    overflow-y: auto;
                    scrollbar-width: thin;
                }

                .scrollable::-webkit-scrollbar {
                    width: 6px;
                }

                .scrollable::-webkit-scrollbar-thumb {
                    background: rgba(255, 255, 255, 0.25);
                    border-radius: 20px;
                }

                .icon-btn {
                    transition: all 0.25s ease;
                }

                .icon-btn:hover {
                    transform: scale(1.18) rotate(8deg);
                    filter: brightness(1.3);
                }

                .collapse-icon {
                    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
                }

                .collapsed .collapse-icon {
                    transform: rotate(-90deg);
                }

                /* Enhanced Test Mode Toggle */
                #test_mode {
                    font-size: 2.1rem;
                    color: #64748b;
                }

                #test_mode.active {
                    color: #22c55e !important;
                    transform: rotate(0deg);
                }

                #test_mode:hover {
                    color: #86efac;
                    transform: scale(1.15);
                }

                /* Settings Gear */
                #open_settings:hover {
                    color: #60a5fa;
                    transform: scale(1.15) rotate(20deg);
                }

                /* General icon button improvements */
                .icon-btn {
                    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
                }

                /* ====================== SLICK MODAL STYLES ====================== */
                .glass-modal {
                    background: rgba(6, 37, 91, 0.95);
                    backdrop-filter: blur(24px);
                    border: 1px solid rgba(255, 255, 255, 0.1);
                    border-radius: 24px;
                    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.65);
                    color: white;
                }

                /* Suggestions dropdown */
                #city_suggestions .list-group-item {
                    background: rgba(15, 23, 42, 0.95);
                    border: none;
                    color: #e2e8f0;
                    padding: 12px 16px;
                }

                #city_suggestions .list-group-item:hover {
                    background: rgba(59, 130, 246, 0.35);
                }

                    </style>
                </head>

                <body>
                    <div class="container-fluid p-3 p-lg-4">
                        <div class="row g-3">
                            <!-- ==================== HOME FRONT COMMAND SIRENS ==================== -->
                            <div class="col-lg-4 col-xl-3">
                                <div class="card table-card header-danger text-white mb-3">
                                    <div class="card-header section-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#pikudBody" style="cursor: pointer">
